@page "/litters"
@using PuppyWeightWatcher.Shared.Models
@inject PuppyApiClient PuppyApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>My Litters</PageTitle>

<h1>Litters</h1>

<div class="mb-3">
    <button class="btn btn-primary" @onclick="NavigateToAddLitter">
        <span class="oi oi-plus" aria-hidden="true"></span> Add New Litter
    </button>
</div>

@if (loading)
{
    <p><em>Loading litters...</em></p>
}
else if (litters == null || !litters.Any())
{
    <div class="alert alert-info">
        <p>No litters tracked yet. Click "Add New Litter" to get started!</p>
    </div>
}
else
{
    <div class="row">
        @foreach (var litter in litters)
        {
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card h-100">
                    <div class="card-header bg-info text-white">
                        <h5 class="mb-0">@litter.Name</h5>
                    </div>
                    <div class="card-body">
                        <p class="card-text">
                            <strong>Date of Birth:</strong> @litter.DateOfBirth.ToString("MM/dd/yyyy")<br />
                            @if (!string.IsNullOrEmpty(litter.Breed))
                            {
                                <span><strong>Breed:</strong> @litter.Breed<br /></span>
                            }
                            <strong>Puppies:</strong> @litter.PuppyCount
                        </p>
                        @if (!string.IsNullOrEmpty(litter.Notes))
                        {
                            <p class="text-muted"><small>@litter.Notes</small></p>
                        }
                    </div>
                    <div class="card-footer">
                        <button class="btn btn-sm btn-primary" @onclick="() => NavigateToDetails(litter.Id)">
                            View Details
                        </button>
                        <button class="btn btn-sm btn-danger float-end" @onclick="() => DeleteLitter(litter.Id)">
                            Delete
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private List<Litter>? litters;
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadLitters();
    }

    private async Task LoadLitters()
    {
        loading = true;
        litters = await PuppyApi.GetAllLittersAsync();
        loading = false;
    }

    private void NavigateToAddLitter()
    {
        Navigation.NavigateTo("/litters/add");
    }

    private void NavigateToDetails(Guid litterId)
    {
        Navigation.NavigateTo($"/litters/{litterId}");
    }

    private async Task DeleteLitter(Guid litterId)
    {
        if (await PuppyApi.DeleteLitterAsync(litterId))
        {
            await LoadLitters();
        }
    }
}
