@page "/litters/{LitterId:guid}"
@using PuppyWeightWatcher.Shared.Models
@inject PuppyApiClient PuppyApi
@inject NavigationManager Navigation
@inject IJSRuntime JS
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Litter Details</PageTitle>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (litter == null)
{
    <div class="alert alert-danger">
        <p>Litter not found.</p>
    </div>
    <button class="btn btn-secondary" @onclick="GoBack">Go Back</button>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div class="d-flex align-items-center gap-2">
            <h1>@litter.Name</h1>
            @if (litter.UserRole != null)
            {
                <span class="badge @GetRoleBadgeClass(litter.UserRole.Value)">@litter.UserRole.Value</span>
            }
        </div>
        <button class="btn btn-secondary" @onclick="GoBack">Back to Litters</button>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Litter Information</h5>
                    @if (CanEdit)
                    {
                        <button class="btn btn-sm btn-light" @onclick="EditLitter">Edit</button>
                    }
                </div>
                <div class="card-body">
                    <p><strong>Date of Birth:</strong> @litter.DateOfBirth.ToString("MM/dd/yyyy")</p>
                    <p><strong>Breed:</strong> @(string.IsNullOrEmpty(litter.Breed) ? "Unknown" : litter.Breed)</p>
                    <p><strong>Puppies in Litter:</strong> @litterPuppies.Count</p>
                    @if (!string.IsNullOrEmpty(litter.Notes))
                    {
                        <p><strong>Notes:</strong> @litter.Notes</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Puppies in this Litter</h5>
            @if (CanEdit)
            {
                <div class="d-flex gap-2">
                    <button class="btn btn-light btn-sm" @onclick="ToggleAddExisting">
                        @(showAddExisting ? "Cancel" : "Add Existing Puppy")
                    </button>
                    <button class="btn btn-light btn-sm" @onclick="AddNewPuppyToLitter">
                        Add New Puppy
                    </button>
                </div>
            }
        </div>
        <div class="card-body">
            @if (showAddExisting)
            {
                <div class="mb-3 p-3 bg-light rounded">
                    <h6>Add Existing Puppies to Litter</h6>
                    <p class="text-muted"><small>Select one or more puppies, then click "Add Selected". Their date of birth and breed will be updated to match this litter.</small></p>
                    @if (availablePuppies.Any())
                    {
                        <div class="row">
                            @foreach (var puppy in availablePuppies)
                            {
                                <div class="col-md-4 mb-2">
                                    <div class="form-check border rounded p-2 h-100 @(selectedPuppyIds.Contains(puppy.Id) ? "border-primary bg-white" : "")">
                                        <input class="form-check-input" type="checkbox" id="puppy-@puppy.Id"
                                               checked="@selectedPuppyIds.Contains(puppy.Id)"
                                               @onchange="() => TogglePuppySelection(puppy.Id)" />
                                        <label class="form-check-label w-100" for="puppy-@puppy.Id" style="cursor:pointer;">
                                            @(string.IsNullOrEmpty(puppy.Name) ? $"Puppy ({puppy.CollarColor})" : puppy.Name)
                                        </label>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="mt-2 d-flex gap-2 align-items-center">
                            <button class="btn btn-primary" @onclick="AddSelectedPuppies" disabled="@(!selectedPuppyIds.Any())">
                                Add Selected (@selectedPuppyIds.Count)
                            </button>
                            <button class="btn btn-link btn-sm" @onclick="SelectAllPuppies">Select All</button>
                            <button class="btn btn-link btn-sm" @onclick="ClearSelection">Clear</button>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">No unassigned puppies available.</p>
                    }
                </div>
            }

            @if (!litterPuppies.Any())
            {
                <p class="text-muted">No puppies in this litter yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th>Collar Color</th>
                                <th>Name</th>
                                <th>Gender</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var puppy in litterPuppies)
                            {
                                <tr>
                                    <td>@puppy.CollarColor</td>
                                    <td>@(string.IsNullOrEmpty(puppy.Name) ? "Not named" : puppy.Name)</td>
                                    <td>@(string.IsNullOrEmpty(puppy.Gender) ? "Unknown" : puppy.Gender)</td>
                                    <td>
                                        <button class="btn btn-sm btn-primary me-1" @onclick="() => ViewPuppy(puppy.Id)">
                                            View
                                        </button>
                                        @if (CanEdit)
                                        {
                                            <button class="btn btn-sm btn-outline-danger" @onclick="() => RemovePuppy(puppy.Id)">
                                                Remove
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @if (puppyWeights.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Litter Weight Comparison</h5>
                <div class="btn-group btn-group-sm">
                    <button class="btn @DaysButtonClass" @onclick="SetTimeframeDays">
                        Days
                    </button>
                    <button class="btn @WeeksButtonClass" @onclick="SetTimeframeWeeks">
                        Weeks
                    </button>
                </div>
            </div>
            <div class="card-body">
                <div style="position: relative; height: 350px;">
                    <canvas id="litterWeightChart"></canvas>
                </div>
            </div>
        </div>
    }

    @if (CanEdit)
    {
        <div class="card mb-4">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0">Members</h5>
            </div>
            <div class="card-body">
                @if (members.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover">
                            <thead>
                                <tr>
                                    <th>Email</th>
                                    <th>Role</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var member in members)
                                {
                                    <tr>
                                        <td>@member.UserId</td>
                                        <td><span class="badge @GetRoleBadgeClass(member.Role)">@member.Role</span></td>
                                        <td>
                                            @if (member.Role != LitterRole.Owner && CanRemoveMember(member))
                                            {
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveMember(member.Id)">
                                                    Remove
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No additional members.</p>
                }

                <hr />
                <h6>Invite a Member</h6>
                @if (!string.IsNullOrEmpty(inviteError))
                {
                    <div class="alert alert-danger py-1">@inviteError</div>
                }
                @if (!string.IsNullOrEmpty(inviteSuccess))
                {
                    <div class="alert alert-success py-1">@inviteSuccess</div>
                }
                <div class="row g-2 align-items-end">
                    <div class="col-md-5">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" @bind="inviteEmail" placeholder="user@example.com" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Role</label>
                        <select class="form-select" @bind="inviteRole">
                            <option value="@LitterRole.Viewer">Viewer</option>
                            @if (CanDelete)
                            {
                                <option value="@LitterRole.CoOwner">Co-Owner</option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <button class="btn btn-primary w-100" @onclick="InviteMember">Invite</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid LitterId { get; set; }

    private Litter? litter;
    private List<Puppy> litterPuppies = new();
    private List<Puppy> availablePuppies = new();
    private HashSet<Guid> selectedPuppyIds = new();
    private bool loading = true;
    private bool showAddExisting = false;
    private List<LitterMember> members = new();
    private string inviteEmail = "";
    private LitterRole inviteRole = LitterRole.Viewer;
    private string? inviteError;
    private string? inviteSuccess;

    private Dictionary<Guid, List<WeightEntry>> puppyWeights = new();
    private string chartTimeframe = "days";
    private bool chartRendered = false;

    private bool CanEdit => litter?.UserRole is LitterRole.Owner or LitterRole.CoOwner;
    private bool CanDelete => litter?.UserRole is LitterRole.Owner;

    private static string GetRoleBadgeClass(LitterRole role) => role switch
    {
        LitterRole.Owner => "bg-primary",
        LitterRole.CoOwner => "bg-success",
        LitterRole.Viewer => "bg-secondary",
        _ => "bg-secondary"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        chartRendered = false;
        litter = await PuppyApi.GetLitterByIdAsync(LitterId);
        litterPuppies = await PuppyApi.GetPuppiesByLitterIdAsync(LitterId);
        members = await PuppyApi.GetLitterMembersAsync(LitterId);

        puppyWeights.Clear();
        if (litterPuppies.Any())
        {
            var weightTasks = litterPuppies.Select(async p =>
            {
                var weights = await PuppyApi.GetWeightEntriesAsync(p.Id);
                return (p.Id, weights);
            });
            foreach (var (id, weights) in await Task.WhenAll(weightTasks))
            {
                if (weights.Any())
                    puppyWeights[id] = weights;
            }
        }

        loading = false;
    }

    private async Task ToggleAddExisting()
    {
        showAddExisting = !showAddExisting;
        if (showAddExisting)
        {
            selectedPuppyIds.Clear();
            await LoadAvailablePuppies();
        }
        else
        {
            selectedPuppyIds.Clear();
        }
    }

    private async Task LoadAvailablePuppies()
    {
        var allPuppies = await PuppyApi.GetAllPuppiesAsync();
        availablePuppies = allPuppies.Where(p => p.LitterId == null).ToList();
    }

    private void TogglePuppySelection(Guid puppyId)
    {
        if (!selectedPuppyIds.Remove(puppyId))
            selectedPuppyIds.Add(puppyId);
    }

    private void SelectAllPuppies()
    {
        selectedPuppyIds = availablePuppies.Select(p => p.Id).ToHashSet();
    }

    private void ClearSelection()
    {
        selectedPuppyIds.Clear();
    }

    private async Task AddSelectedPuppies()
    {
        if (!selectedPuppyIds.Any())
            return;

        await PuppyApi.AddPuppiesToLitterAsync(LitterId, selectedPuppyIds.ToList());
        showAddExisting = false;
        selectedPuppyIds.Clear();
        await LoadData();
    }

    private async Task RemovePuppy(Guid puppyId)
    {
        await PuppyApi.RemovePuppyFromLitterAsync(puppyId);
        await LoadData();
    }

    private void AddNewPuppyToLitter()
    {
        Navigation.NavigateTo($"/puppies/add?litterId={LitterId}");
    }

    private void ViewPuppy(Guid puppyId)
    {
        Navigation.NavigateTo($"/puppies/{puppyId}");
    }

    private void EditLitter()
    {
        Navigation.NavigateTo($"/litters/edit/{LitterId}");
    }

    private bool CanRemoveMember(LitterMember member)
    {
        if (litter?.UserRole == LitterRole.Owner)
            return member.Role != LitterRole.Owner;
        if (litter?.UserRole == LitterRole.CoOwner)
            return member.Role == LitterRole.Viewer;
        return false;
    }

    private async Task InviteMember()
    {
        inviteError = null;
        inviteSuccess = null;

        if (string.IsNullOrWhiteSpace(inviteEmail))
        {
            inviteError = "Please enter an email address.";
            return;
        }

        var result = await PuppyApi.AddLitterMemberAsync(LitterId, inviteEmail.Trim(), inviteRole);
        if (result != null)
        {
            inviteSuccess = $"{inviteEmail} has been added as {inviteRole}.";
            inviteEmail = "";
            inviteRole = LitterRole.Viewer;
            members = await PuppyApi.GetLitterMembersAsync(LitterId);
        }
        else
        {
            inviteError = "Unable to add member. Check that the email is not already a member and you have permission.";
        }
    }

    private async Task RemoveMember(Guid memberId)
    {
        await PuppyApi.RemoveLitterMemberAsync(LitterId, memberId);
        members = await PuppyApi.GetLitterMembersAsync(LitterId);
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/litters");
    }

    private string DaysButtonClass => chartTimeframe == "days" ? "btn-light" : "btn-outline-light";
    private string WeeksButtonClass => chartTimeframe == "weeks" ? "btn-light" : "btn-outline-light";
    private async Task SetTimeframeDays() => await SetTimeframe("days");
    private async Task SetTimeframeWeeks() => await SetTimeframe("weeks");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (puppyWeights.Any() && !chartRendered)
        {
            chartRendered = true;
            await RenderChart();
        }
    }

    private async Task SetTimeframe(string timeframe)
    {
        chartTimeframe = timeframe;
        await RenderChart();
    }

    private async Task RenderChart()
    {
        if (!puppyWeights.Any()) return;

        var allDates = puppyWeights.Values
            .SelectMany(w => w.Select(e => e.Date.Date))
            .Distinct()
            .OrderBy(d => d)
            .ToList();

        string[] labels;
        var datasets = new List<object>();
        var unit = puppyWeights.Values.First().Last().Unit.ToString();

        if (chartTimeframe == "weeks")
        {
            var weekKeys = allDates
                .Select(d =>
                {
                    var cal = System.Globalization.CultureInfo.CurrentCulture.Calendar;
                    var week = cal.GetWeekOfYear(d, System.Globalization.CalendarWeekRule.FirstDay, DayOfWeek.Monday);
                    return new { d.Year, Week = week };
                })
                .Distinct()
                .OrderBy(k => k.Year).ThenBy(k => k.Week)
                .ToList();

            labels = weekKeys.Select(k => $"Wk {k.Week}, {k.Year}").ToArray();

            foreach (var puppy in litterPuppies)
            {
                if (!puppyWeights.TryGetValue(puppy.Id, out var weights)) continue;

                var grouped = weights
                    .GroupBy(w =>
                    {
                        var cal = System.Globalization.CultureInfo.CurrentCulture.Calendar;
                        var week = cal.GetWeekOfYear(w.Date, System.Globalization.CalendarWeekRule.FirstDay, DayOfWeek.Monday);
                        return new { w.Date.Year, Week = week };
                    })
                    .ToDictionary(g => g.Key, g => g.Average(w => w.WeightValue));

                var data = weekKeys.Select(k => grouped.TryGetValue(k, out var v) ? (double?)v : null).ToArray();
                var name = string.IsNullOrEmpty(puppy.Name) ? $"Puppy ({puppy.CollarColor})" : puppy.Name;
                datasets.Add(new { name, color = GetColorValue(puppy.CollarColor), unit, data });
            }
        }
        else
        {
            labels = allDates.Select(d => d.ToString("MM/dd")).ToArray();

            foreach (var puppy in litterPuppies)
            {
                if (!puppyWeights.TryGetValue(puppy.Id, out var weights)) continue;

                var weightByDate = weights.ToDictionary(w => w.Date.Date, w => w.WeightValue);
                var data = allDates.Select(d => weightByDate.TryGetValue(d, out var v) ? (double?)v : null).ToArray();
                var name = string.IsNullOrEmpty(puppy.Name) ? $"Puppy ({puppy.CollarColor})" : puppy.Name;
                datasets.Add(new { name, color = GetColorValue(puppy.CollarColor), unit, data });
            }
        }

        await JS.InvokeVoidAsync("weightChart.renderMulti", "litterWeightChart", labels, datasets);
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("weightChart.destroyMulti");
        }
        catch (JSDisconnectedException) { }
        catch (InvalidOperationException) { }
    }

    private static string GetColorValue(string collarColor)
    {
        return collarColor.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "light green" => "#90ee90",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "pink" => "#d63384",
            "orange" => "#fd7e14",
            "black" => "#212529",
            "white" => "#6c757d",
            "brown" => "#795548",
            "gray" or "grey" => "#adb5bd",
            _ => "#6c757d"
        };
    }
}
