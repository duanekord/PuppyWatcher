@page "/Account/Login"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using PuppyWeightWatcher.Web.Data
@attribute [AllowAnonymous]
@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager NavigationManager

<PageTitle>Login</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="mb-4">Login</h1>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">@errorMessage</div>
        }

        <EditForm Model="Input" method="post" OnValidSubmit="LoginUser" FormName="login">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="mb-3">
                <label for="email" class="form-label">Email</label>
                <InputText @bind-Value="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                <ValidationMessage For="() => Input.Email" class="text-danger" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label">Password</label>
                <InputText type="password" @bind-Value="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
                <ValidationMessage For="() => Input.Password" class="text-danger" />
            </div>

            <div class="mb-3 form-check">
                <InputCheckbox @bind-Value="Input.RememberMe" class="form-check-input" id="rememberMe" />
                <label class="form-check-label" for="rememberMe">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">Log in</button>
        </EditForm>

        @if (externalLogins.Any())
        {
            <hr />

            <h5 class="text-center">Or sign in with</h5>
            <div class="d-grid gap-2">
                @foreach (var provider in externalLogins)
                {
                    @if (provider.Name == "Google")
                    {
                        <div class="text-center">
                            <a href="/Account/ExternalLogin?provider=@provider.Name&returnUrl=@Uri.EscapeDataString(GetSafeReturnUrl())" class="google-login-btn">
                                <img src="images/google-logo.svg" alt="" />
                                Sign in with Google
                            </a>
                        </div>
                    }
                }
                @foreach (var provider in externalLogins)
                {
                    @if (provider.Name == "Microsoft")
                    {
                        <div class="text-center">
                            <a href="/Account/ExternalLogin?provider=@provider.Name&returnUrl=@Uri.EscapeDataString(GetSafeReturnUrl())" class="ms-login-btn">
                                <img src="images/microsoft-logo.svg" alt="Sign in with Microsoft" />
                            </a>
                        </div>
                    }
                    else if (provider.Name != "Google")
                    {
                        <a href="/Account/ExternalLogin?provider=@provider.Name&returnUrl=@Uri.EscapeDataString(GetSafeReturnUrl())" class="btn btn-outline-secondary">
                            @provider.DisplayName
                        </a>
                    }
                }
            </div>
        }

        <hr />

        <p class="text-center">
            Don't have an account? <a href="/Account/Register">Register</a>
        </p>
    </div>
</div>

@code {
    private string? errorMessage;
    private IEnumerable<Microsoft.AspNetCore.Authentication.AuthenticationScheme> externalLogins = [];

    [SupplyParameterFromForm]
    private LoginModel Input { get; set; } = new();

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    protected override async Task OnInitializedAsync()
    {
        externalLogins = await SignInManager.GetExternalAuthenticationSchemesAsync();
    }

    private async Task LoginUser()
    {
        try
        {
            var result = await SignInManager.PasswordSignInAsync(Input.Email, Input.Password, Input.RememberMe, lockoutOnFailure: true);

            if (result.Succeeded)
            {
                NavigationManager.NavigateTo(GetSafeReturnUrl(), forceLoad: true);
            }
            else if (result.IsLockedOut)
            {
                errorMessage = "Account locked out. Please try again later.";
            }
            else
            {
                errorMessage = "Invalid login attempt.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Unable to connect. Please try again in a moment.";
        }
    }

    private string GetSafeReturnUrl()
    {
        if (!string.IsNullOrEmpty(ReturnUrl) && Uri.TryCreate(ReturnUrl, UriKind.Relative, out _))
        {
            return ReturnUrl;
        }
        return "/";
    }

    private sealed class LoginModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";

        [Required]
        [DataType(DataType.Password)]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; } = true;
    }
}
