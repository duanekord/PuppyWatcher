@page "/Account/ExternalLoginCallback"
@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using PuppyWeightWatcher.Web.Data
@attribute [AllowAnonymous]
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject ILogger<ExternalLoginCallback> Logger

<PageTitle>External Login</PageTitle>

<div class="row justify-content-center">
    <div class="col-md-5">
        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger">
                <h4>Login failed</h4>
                <p>@errorMessage</p>
                <a href="/Account/Login" class="btn btn-primary">Back to Login</a>
            </div>
        }
        else
        {
            <div class="text-center py-4">
                <div class="spinner-border text-primary mb-3" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p>Processing external login...</p>
            </div>
        }
    </div>
</div>

@code {
    private string? errorMessage;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    [CascadingParameter]
    private HttpContext HttpContext { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        const int maxRetries = 3;

        ExternalLoginInfo? info = null;
        for (int attempt = 1; attempt <= maxRetries; attempt++)
        {
            try
            {
                info = await SignInManager.GetExternalLoginInfoAsync();
                break;
            }
            catch (Exception ex) when (attempt < maxRetries)
            {
                Logger.LogWarning(ex, "GetExternalLoginInfoAsync attempt {Attempt}/{MaxRetries} failed. Retrying...", attempt, maxRetries);
                await Task.Delay(TimeSpan.FromSeconds(attempt * 2));
            }
        }

        if (info is null)
        {
            Logger.LogWarning("GetExternalLoginInfoAsync returned null. External cookie may be missing.");
            errorMessage = "Error loading external login information. Please try again.";
            return;
        }

        // Try to sign in with existing external login
        try
        {
            var result = await SignInManager.ExternalLoginSignInAsync(
                info.LoginProvider, info.ProviderKey, isPersistent: true, bypassTwoFactor: true);

            if (result.Succeeded)
            {
                Logger.LogInformation("{Name} logged in with {LoginProvider} provider.",
                    info.Principal.Identity?.Name, info.LoginProvider);
                RedirectTo(ReturnUrl ?? "/");
                return;
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "ExternalLoginSignInAsync failed for {LoginProvider}. Attempting user creation flow.", info.LoginProvider);
        }

        // User does not have an account — create one
        var email = info.Principal.FindFirstValue(ClaimTypes.Email);
        if (string.IsNullOrEmpty(email))
        {
            errorMessage = "Email claim not received from external provider. Please contact support.";
            return;
        }

        try
        {
            var user = await UserManager.FindByEmailAsync(email);
            if (user is null)
            {
                user = new ApplicationUser
                {
                    UserName = email,
                    Email = email
                };

                var createResult = await UserManager.CreateAsync(user);
                if (!createResult.Succeeded)
                {
                    errorMessage = "Error creating user account: " +
                        string.Join(", ", createResult.Errors.Select(e => e.Description));
                    return;
                }
            }

            // Only add the login if it doesn't already exist for this user
            var existingLogins = await UserManager.GetLoginsAsync(user);
            if (!existingLogins.Any(l => l.LoginProvider == info.LoginProvider && l.ProviderKey == info.ProviderKey))
            {
                var addLoginResult = await UserManager.AddLoginAsync(user, info);
                if (!addLoginResult.Succeeded)
                {
                    errorMessage = "Error adding external login: " +
                        string.Join(", ", addLoginResult.Errors.Select(e => e.Description));
                    return;
                }
            }

            await SignInManager.SignInAsync(user, isPersistent: true, info.LoginProvider);
            Logger.LogInformation("{Email} created an account using {LoginProvider} provider.",
                email, info.LoginProvider);
            RedirectTo(ReturnUrl ?? "/");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error during external login user creation for {Email}", email);
            errorMessage = "An error occurred during login. Please try again.";
        }
    }

    private void RedirectTo(string url)
    {
        if (!Uri.TryCreate(url, UriKind.Relative, out _))
        {
            url = "/";
        }
        HttpContext.Response.Redirect(url);
    }
}
