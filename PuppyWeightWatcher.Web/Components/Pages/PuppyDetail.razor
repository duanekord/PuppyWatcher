@page "/puppies/{PuppyId:guid}"
@using PuppyWeightWatcher.Shared.Models
@using Microsoft.AspNetCore.Components.Forms
@inject PuppyApiClient PuppyApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Puppy Details</PageTitle>

@if (loading)
{
    <p><em>Loading...</em></p>
}
else if (puppy == null)
{
    <div class="alert alert-danger">
        <p>Puppy not found.</p>
    </div>
    <button class="btn btn-secondary" @onclick="GoBack">Go Back</button>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>@(string.IsNullOrEmpty(puppy.Name) ? $"Puppy ({puppy.CollarColor})" : puppy.Name)</h1>
        <button class="btn btn-secondary" @onclick="GoBack">Back to List</button>
    </div>

    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header" style="background-color: @GetColorValue(puppy.CollarColor); color: @GetTextColor(puppy.CollarColor);">
                    <h5 class="mb-0">Puppy Information</h5>
                </div>
                <div class="card-body">
                    <p><strong>Collar Color:</strong> @puppy.CollarColor</p>
                    <p><strong>Name:</strong> @(string.IsNullOrEmpty(puppy.Name) ? "Not named yet" : puppy.Name)</p>
                    <p><strong>Breed:</strong> @(string.IsNullOrEmpty(puppy.Breed) ? "Unknown" : puppy.Breed)</p>
                    <p><strong>Gender:</strong> @(string.IsNullOrEmpty(puppy.Gender) ? "Unknown" : puppy.Gender)</p>
                    <p><strong>Date of Birth:</strong> @puppy.DateOfBirth.ToString("MM/dd/yyyy")</p>
                    <p><strong>Age:</strong> @CalculateAge(puppy.DateOfBirth)</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Weight Statistics</h5>
                </div>
                <div class="card-body">
                    @if (statistics != null && statistics.CurrentWeight.HasValue)
                    {
                        <p><strong>Current Weight:</strong> @statistics.CurrentWeight.Value.ToString("F2") @statistics.CurrentWeightUnit</p>
                        <p><strong>Total Entries:</strong> @statistics.TotalWeightEntries</p>
                        <p><strong>Average Weight:</strong> @(statistics.AverageWeight?.ToString("F2") ?? "N/A") @statistics.CurrentWeightUnit</p>

                        @if (statistics.DayOverDayChange.HasValue)
                        {
                            <p>
                                <strong>Day-over-Day:</strong> 
                                <span class="@(statistics.DayOverDayChange >= 0 ? "text-success" : "text-danger")">
                                    @(statistics.DayOverDayChange >= 0 ? "+" : "")@statistics.DayOverDayChange.Value.ToString("F2") 
                                    (@(statistics.DayOverDayPercentChange >= 0 ? "+" : "")@statistics.DayOverDayPercentChange.Value.ToString("F1")%)
                                </span>
                            </p>
                        }

                        @if (statistics.WeekOverWeekChange.HasValue)
                        {
                            <p>
                                <strong>Week-over-Week:</strong> 
                                <span class="@(statistics.WeekOverWeekChange >= 0 ? "text-success" : "text-danger")">
                                    @(statistics.WeekOverWeekChange >= 0 ? "+" : "")@statistics.WeekOverWeekChange.Value.ToString("F2") 
                                    (@(statistics.WeekOverWeekPercentChange >= 0 ? "+" : "")@statistics.WeekOverWeekPercentChange.Value.ToString("F1")%)
                                </span>
                            </p>
                        }

                        @if (statistics.TotalWeightGain.HasValue)
                        {
                            <p>
                                <strong>Total Gain:</strong> 
                                <span class="@(statistics.TotalWeightGain >= 0 ? "text-success" : "text-danger")">
                                    @(statistics.TotalWeightGain >= 0 ? "+" : "")@statistics.TotalWeightGain.Value.ToString("F2") 
                                    (@(statistics.TotalPercentGain >= 0 ? "+" : "")@statistics.TotalPercentGain.Value.ToString("F1")%)
                                </span>
                            </p>
                        }
                    }
                    else
                    {
                        <p class="text-muted">No weight data recorded yet.</p>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card mb-4">
                <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Weight History</h5>
                    <button class="btn btn-light btn-sm" @onclick="() => showAddWeight = !showAddWeight">
                        @(showAddWeight ? "Cancel" : "Add Weight")
                    </button>
                </div>
                <div class="card-body">
                    @if (showAddWeight)
                    {
                        <div class="mb-3 p-3 bg-light rounded">
                            <h6>Add Weight Entry</h6>
                            <div class="row">
                                <div class="col-md-4">
                                    <label class="form-label">Date</label>
                                    <input type="date" class="form-control" @bind="newWeightDate" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Weight</label>
                                    <input type="number" step="0.01" class="form-control" @bind="newWeightValue" placeholder="Enter weight" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Unit</label>
                                    <select class="form-control" @bind="newWeightUnit">
                                        <option value="@WeightUnit.Grams">Grams</option>
                                        <option value="@WeightUnit.Pounds">Pounds</option>
                                    </select>
                                </div>
                            </div>
                            <div class="row mt-2">
                                <div class="col-12">
                                    <label class="form-label">Notes (optional)</label>
                                    <input type="text" class="form-control" @bind="newWeightNotes" placeholder="Add notes..." />
                                </div>
                            </div>
                            <button class="btn btn-primary btn-sm mt-2" @onclick="AddWeightEntry">Save Weight</button>
                        </div>
                    }

                    @if (weights == null || !weights.Any())
                    {
                        <p class="text-muted">No weight entries recorded yet.</p>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead>
                                    <tr>
                                        <th>Date</th>
                                        <th>Weight</th>
                                        <th>Change</th>
                                        <th>% Change</th>
                                        <th>Notes</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = weights.Count - 1; i >= 0; i--)
                                    {
                                        var weight = weights[i];
                                        var previousWeight = i > 0 ? weights[i - 1] : null;
                                        var change = previousWeight != null ? weight.WeightValue - previousWeight.WeightValue : 0;
                                        var percentChange = previousWeight != null && previousWeight.WeightValue > 0 
                                            ? (change / previousWeight.WeightValue) * 100 : 0;

                                        <tr>
                                            <td>@weight.Date.ToString("MM/dd/yyyy")</td>
                                            <td>@weight.WeightValue.ToString("F2") @weight.Unit</td>
                                            <td>
                                                @if (previousWeight != null)
                                                {
                                                    <span class="@(change >= 0 ? "text-success" : "text-danger")">
                                                        @(change >= 0 ? "+" : "")@change.ToString("F2")
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span>-</span>
                                                }
                                            </td>
                                            <td>
                                                @if (previousWeight != null)
                                                {
                                                    <span class="@(percentChange >= 0 ? "text-success" : "text-danger")">
                                                        @(percentChange >= 0 ? "+" : "")@percentChange.ToString("F1")%
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span>-</span>
                                                }
                                            </td>
                                            <td>@(string.IsNullOrEmpty(weight.Notes) ? "-" : weight.Notes)</td>
                                            <td>
                                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteWeight(weight.Id)">
                                                    Delete
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card">
                <div class="card-header bg-info text-white d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Shot Records</h5>
                    <button class="btn btn-light btn-sm" @onclick="() => showAddShot = !showAddShot">
                        @(showAddShot ? "Cancel" : "Add Shot")
                    </button>
                </div>
                <div class="card-body">
                    @if (showAddShot)
                    {
                        <div class="mb-3 p-3 bg-light rounded">
                            <h6>Add Shot Record</h6>
                            <label class="form-label">Vaccination Type</label>
                            <input type="text" class="form-control mb-2" @bind="newShotType" placeholder="e.g., DHPP, Rabies" />

                            <label class="form-label">Date Administered</label>
                            <input type="date" class="form-control mb-2" @bind="newShotDate" />

                            <label class="form-label">Administered By (optional)</label>
                            <input type="text" class="form-control mb-2" @bind="newShotAdministeredBy" placeholder="Vet name" />

                            <label class="form-label">Notes (optional)</label>
                            <textarea class="form-control mb-2" @bind="newShotNotes" rows="2" placeholder="Additional information..."></textarea>

                            <button class="btn btn-primary btn-sm" @onclick="AddShotRecord">Save Shot</button>
                        </div>
                    }

                    @if (puppy.ShotRecords == null || !puppy.ShotRecords.Any())
                    {
                        <p class="text-muted">No shot records yet.</p>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var shot in puppy.ShotRecords.OrderByDescending(s => s.DateAdministered))
                            {
                                <div class="list-group-item">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="mb-1">@shot.VaccinationType</h6>
                                        <button class="btn btn-sm btn-danger" @onclick="() => DeleteShot(shot.Id)">
                                            Delete
                                        </button>
                                    </div>
                                    <p class="mb-1"><small>Date: @shot.DateAdministered.ToString("MM/dd/yyyy")</small></p>
                                    @if (!string.IsNullOrEmpty(shot.AdministeredBy))
                                    {
                                        <p class="mb-1"><small>By: @shot.AdministeredBy</small></p>
                                    }
                                    @if (!string.IsNullOrEmpty(shot.Notes))
                                    {
                                        <p class="mb-0"><small>@shot.Notes</small></p>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-12">
            <div class="card mb-4">
                <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">Photos (@(photos?.Count ?? 0))</h5>
                    <button class="btn btn-dark btn-sm" @onclick="() => showAddPhoto = !showAddPhoto">
                        @(showAddPhoto ? "Cancel" : "Add Photo")
                    </button>
                </div>
                <div class="card-body">
                    @if (showAddPhoto)
                    {
                        <div class="mb-3 p-3 bg-light rounded">
                            <h6>Upload Photo</h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <label class="form-label">Photo File</label>
                                    <InputFile class="form-control" OnChange="OnPhotoFileSelected" accept="image/*" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Date Taken</label>
                                    <input type="date" class="form-control" @bind="newPhotoDateTaken" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Caption (optional)</label>
                                    <input type="text" class="form-control" @bind="newPhotoCaption" placeholder="Describe this photo..." />
                                </div>
                            </div>
                            @if (selectedFile != null)
                            {
                                <p class="mt-2 mb-1 text-muted"><small>Selected: @selectedFile.Name (@((selectedFile.Size / 1024.0).ToString("F0")) KB)</small></p>
                            }
                            @if (!string.IsNullOrEmpty(photoUploadError))
                            {
                                <div class="alert alert-danger mt-2 py-1">@photoUploadError</div>
                            }
                            <button class="btn btn-primary btn-sm mt-2" @onclick="UploadPhoto" disabled="@(selectedFile == null || uploadingPhoto)">
                                @if (uploadingPhoto)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                }
                                Upload
                            </button>
                        </div>
                    }

                    @if (photos == null || !photos.Any())
                    {
                        <p class="text-muted">No photos yet. Add a photo to track your puppy's visual progress!</p>
                    }
                    else
                    {
                        <div class="row">
                            @foreach (var photo in photos)
                            {
                                <div class="col-md-4 col-lg-3 mb-3">
                                    <div class="card h-100 @(photo.IsProfilePhoto ? "border-warning border-2" : "")">
                                        <img src="data:@photo.ContentType;base64,@photo.Base64Data"
                                             alt="@(photo.Caption ?? "Puppy photo")"
                                             class="card-img-top" style="height: 200px; object-fit: cover; cursor: pointer;"
                                             @onclick="() => viewingPhoto = photo" />
                                        @if (photo.IsProfilePhoto)
                                        {
                                            <span class="badge bg-warning text-dark position-absolute top-0 start-0 m-1">Profile Pic</span>
                                        }
                                        <div class="card-body p-2">
                                            <small class="text-muted">@photo.DateTaken.ToString("MM/dd/yyyy")</small>
                                            @if (!string.IsNullOrEmpty(photo.Caption))
                                            {
                                                <p class="mb-0"><small>@photo.Caption</small></p>
                                            }
                                        </div>
                                        <div class="card-footer p-1 d-flex gap-1">
                                            @if (!photo.IsProfilePhoto)
                                            {
                                                <button class="btn btn-outline-warning btn-sm flex-grow-1" @onclick="() => SetAsProfilePhoto(photo.Id)">
                                                    Set as Profile
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeletePhoto(photo.Id)">
                                                Delete
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (viewingPhoto != null)
    {
        <div class="modal d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.8);" @onclick="() => viewingPhoto = null">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content" @onclick:stopPropagation="true">
                    <div class="modal-header">
                        <h5 class="modal-title">@(viewingPhoto.Caption ?? "Puppy Photo") - @viewingPhoto.DateTaken.ToString("MM/dd/yyyy")</h5>
                        <button type="button" class="btn-close" @onclick="() => viewingPhoto = null"></button>
                    </div>
                    <div class="modal-body text-center p-0">
                        <img src="data:@viewingPhoto.ContentType;base64,@viewingPhoto.Base64Data"
                             alt="@(viewingPhoto.Caption ?? "Puppy photo")"
                             style="max-width: 100%; max-height: 70vh; object-fit: contain;" />
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter]
    public Guid PuppyId { get; set; }

    private Puppy? puppy;
    private List<WeightEntry>? weights;
    private WeightStatistics? statistics;
    private bool loading = true;
    private bool showAddWeight = false;
    private bool showAddShot = false;

    private List<PuppyPhoto>? photos;
    private bool showAddPhoto = false;
    private bool uploadingPhoto = false;
    private IBrowserFile? selectedFile;
    private DateTime newPhotoDateTaken = DateTime.Today;
    private string newPhotoCaption = string.Empty;
    private string photoUploadError = string.Empty;
    private PuppyPhoto? viewingPhoto;

    private DateTime newWeightDate = DateTime.Today;
    private double newWeightValue;
    private WeightUnit newWeightUnit = WeightUnit.Grams;
    private string newWeightNotes = string.Empty;

    private string newShotType = string.Empty;
    private DateTime newShotDate = DateTime.Today;
    private string newShotAdministeredBy = string.Empty;
    private string newShotNotes = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        loading = true;
        puppy = await PuppyApi.GetPuppyByIdAsync(PuppyId);
        if (puppy != null)
        {
            weights = await PuppyApi.GetWeightEntriesAsync(PuppyId);
            statistics = await PuppyApi.GetWeightStatisticsAsync(PuppyId);
            photos = await PuppyApi.GetPhotosAsync(PuppyId);
        }
        loading = false;
    }

    private async Task AddWeightEntry()
    {
        if (newWeightValue <= 0) return;

        var entry = new WeightEntry
        {
            PuppyId = PuppyId,
            Date = newWeightDate,
            WeightValue = newWeightValue,
            Unit = newWeightUnit,
            Notes = newWeightNotes
        };

        await PuppyApi.AddWeightEntryAsync(PuppyId, entry);

        newWeightValue = 0;
        newWeightNotes = string.Empty;
        showAddWeight = false;

        await LoadData();
    }

    private async Task DeleteWeight(Guid weightId)
    {
        await PuppyApi.DeleteWeightEntryAsync(weightId);
        await LoadData();
    }

    private async Task AddShotRecord()
    {
        if (string.IsNullOrWhiteSpace(newShotType)) return;

        var shot = new ShotRecord
        {
            VaccinationType = newShotType,
            DateAdministered = newShotDate,
            AdministeredBy = newShotAdministeredBy,
            Notes = newShotNotes
        };

        await PuppyApi.AddShotRecordAsync(PuppyId, shot);

        newShotType = string.Empty;
        newShotAdministeredBy = string.Empty;
        newShotNotes = string.Empty;
        showAddShot = false;

        await LoadData();
    }

    private async Task DeleteShot(Guid shotId)
    {
        await PuppyApi.DeleteShotRecordAsync(PuppyId, shotId);
        await LoadData();
    }

    private void OnPhotoFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        photoUploadError = string.Empty;
    }

    private async Task UploadPhoto()
    {
        if (selectedFile == null) return;

        photoUploadError = string.Empty;
        uploadingPhoto = true;

        try
        {
            const long maxSize = 10 * 1024 * 1024; // 10 MB
            using var stream = selectedFile.OpenReadStream(maxSize);
            await PuppyApi.UploadPhotoAsync(
                PuppyId,
                stream,
                selectedFile.Name,
                selectedFile.ContentType,
                string.IsNullOrWhiteSpace(newPhotoCaption) ? null : newPhotoCaption.Trim(),
                newPhotoDateTaken);

            selectedFile = null;
            newPhotoCaption = string.Empty;
            newPhotoDateTaken = DateTime.Today;
            showAddPhoto = false;

            await LoadData();
        }
        catch (Exception ex)
        {
            photoUploadError = $"Upload failed: {ex.Message}";
        }
        finally
        {
            uploadingPhoto = false;
        }
    }

    private async Task DeletePhoto(Guid photoId)
    {
        await PuppyApi.DeletePhotoAsync(PuppyId, photoId);
        await LoadData();
    }

    private async Task SetAsProfilePhoto(Guid photoId)
    {
        await PuppyApi.SetProfilePhotoAsync(PuppyId, photoId);
        await LoadData();
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/puppies");
    }

    private string CalculateAge(DateTime dateOfBirth)
    {
        var age = DateTime.Now - dateOfBirth;
        if (age.TotalDays < 7)
            return $"{(int)age.TotalDays} day{(age.TotalDays >= 2 ? "s" : "")} old";
        else if (age.TotalDays < 30)
            return $"{(int)(age.TotalDays / 7)} week{(age.TotalDays >= 14 ? "s" : "")} old";
        else
            return $"{(int)(age.TotalDays / 30)} month{(age.TotalDays >= 60 ? "s" : "")} old";
    }

    private string GetColorValue(string collarColor)
    {
        return collarColor.ToLower() switch
        {
            "red" => "#dc3545",
            "blue" => "#0d6efd",
            "green" => "#198754",
            "yellow" => "#ffc107",
            "purple" => "#6f42c1",
            "pink" => "#d63384",
            "orange" => "#fd7e14",
            "black" => "#212529",
            "white" => "#f8f9fa",
            "brown" => "#795548",
            "gray" or "grey" => "#6c757d",
            _ => "#6c757d"
        };
    }

    private string GetTextColor(string collarColor)
    {
        var darkColors = new[] { "red", "blue", "green", "purple", "black", "brown", "gray", "grey" };
        return darkColors.Contains(collarColor.ToLower()) ? "white" : "black";
    }
}
